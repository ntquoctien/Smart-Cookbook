# Backend URL used by the Expo app for YOLO vision detection.
#
# Android emulator:
# EXPO_PUBLIC_VISION_API_BASE_URL=http://10.0.2.2:8000
#
# iOS simulator:
# EXPO_PUBLIC_VISION_API_BASE_URL=http://127.0.0.1:8000
#
# Physical phone on the same Wi-Fi as this computer:
# EXPO_PUBLIC_VISION_API_BASE_URL=http://<YOUR_COMPUTER_IPV4>:8000

EXPO_PUBLIC_VISION_API_BASE_URL=http://192.168.1.166:8000
EXPO_PUBLIC_USE_MOCK_VISION=false
